# ========================================
# Frontend Environment Variables
# (Place these in frontend/.env)
# ========================================
# IMPORTANT: Do NOT include a trailing slash!
# ✅ Correct: https://my-backend.onrender.com
# ❌ Wrong:   https://my-backend.onrender.com/
VITE_BACKEND_URL=http://localhost:5000

# ========================================
# Backend Environment Variables
# (Place these in backend/.env)
# ========================================
PORT=5000
# Leave MONGO_URL blank to use the zero-config in-memory database for local development.
# The medicine database will auto-seed from NIH RxTerms API on first startup.
MONGO_URL=
JWT_SECRET=your_super_secure_jwt_secret_key_here
CORS_ORIGIN=http://localhost:5173
